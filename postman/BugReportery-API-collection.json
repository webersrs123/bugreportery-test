    {
      "name": "Bugs (CRUD)",
      "item": [
        {
          "name": "Create bug",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "apikey",
                "value": "{{api_key}}",
                "type": "text"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Prefer",
                "value": "return=representation",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"BUG-{{$randomInt}}\",\n  \"title\": \"Test bug via API\",\n  \"description\": \"Description\",\n  \"steps\": \"Steps\",\n  \"expected\": \"Expected\",\n  \"actual\": \"Actual\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/rest/v1/bugs",
              "host": ["{{base_url}}"],
              "path": ["rest", "v1", "bugs"]
            }
          },
          "response": []
        },
        {
          "name": "Get all bugs",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "apikey",
                "value": "{{api_key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/rest/v1/bugs",
              "host": ["{{base_url}}"],
              "path": ["rest", "v1", "bugs"]
            }
          },
          "response": []
        },
        {
          "name": "Get bug by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "apikey",
                "value": "{{api_key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/rest/v1/bugs?id=eq.{{bug_id}}",
              "host": ["{{base_url}}"],
              "path": ["rest", "v1", "bugs"],
              "query": [
                {
                  "key": "id",
                  "value": "eq.{{bug_id}}"
                }
              ]
            }
          },
          "response": []
        }
      ]
